[Unit]
Description=Moppu Monitor Dashboard
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/moppu
ExecStart=/opt/moppu/.venv/bin/moppu dashboard --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=moppu-dashboard

[Install]
WantedBy=multi-user.target
