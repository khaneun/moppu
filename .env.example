# === LLM providers ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === YouTube Data API (optional; used for channel metadata / push notifications) ===
YOUTUBE_API_KEY=

# === 한국투자증권 (KIS) OpenAPI ===
# 실전투자 키
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
# "real" for 실전투자, "paper" for 모의투자
KIS_ENV=paper
# 모의투자 전용 키/계좌 (없으면 위 키 공용)
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
# Comma-separated list of allowed chat IDs
TELEGRAM_ALLOWED_CHAT_IDS=

# === Runtime ===
MOPPU_CONFIG_PATH=config/config.yaml
MOPPU_CHANNELS_PATH=config/channels.yaml
LOG_LEVEL=INFO
